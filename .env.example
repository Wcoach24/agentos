# AgentOS — variables de entorno. Copia a .env y rellena.
# Cárgalo con varlock (recomendado por tu skill) o `set -a; source .env; set +a`.

# ---- AUTH DEL MOTOR ----
# NO definas ANTHROPIC_API_KEY. El sistema la borra a propósito para forzar el
# uso del crédito de tu plan Max 20x vía el CLI de Claude Code. Si la pones aquí,
# el SDK facturará pago-por-token en silencio.
#
# Login del plan (una sola vez, interactivo en el Mac Mini):
#   claude            # abre login OAuth en el navegador; guarda credenciales locales
# Comprueba la ruta activa con:  claude /status

# ---- GATES POR EMAIL (Gmail SMTP/IMAP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
IMAP_HOST=imap.gmail.com
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=app_password_de_16_caracteres   # NO tu contraseña real; crea un App Password
DISPATCHER_EMAIL=tu_cuenta@gmail.com       # donde recibes y respondes los [GATE]

# ---- WATCHER / PUENTE ----
WATCHER_POLL_SECONDS=120
REPO_SYNC=local            # "local" (otro proceso deja yaml en inbox) o "git"
REPO_DIR=                  # solo si REPO_SYNC=git: ruta al clon de alvaro-pipeline

# ---- GATES POR TELEGRAM (recomendado; canal principal) ----
GATE_CHANNEL=telegram                 # "telegram" o "email"
TELEGRAM_BOT_TOKEN=123456:ABC...      # crea el bot con @BotFather
TELEGRAM_CHAT_ID=000000000            # tu chat id (responde al bot y míralo en getUpdates)
